{
  "$schema": "https://opencode.ai/config.json",
  "model": "synthetic/hf:zai-org/GLM-5.2",
  "autoshare": false,
  "autoupdate": true,
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "synthetic": {
      "models": {
        "syn:large:text": {
          "name": "Large text"
        },
        "syn:small:text": {
          "name": "Small text"
        },
        "syn:large:vision": {
          "name": "Large vision"
        },
        "syn:small:vision": {
          "name": "Small vision"
        },
        "hf:zai-org/GLM-5.2": {
          "name": "GLM-5.2",
          "family": "glm",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "structured_output": true,
          "temperature": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "open_weights": true,
          "cost": {
            "input": 1.4,
            "output": 4.4,
            "cache_read": 1.4
          },
          "limit": {
            "context": 524288,
            "output": 65536
          }
        }
      }
    }
  }
}
